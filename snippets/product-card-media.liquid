<div class="media media--transparent media--{{ media_size }} media--hover-effect"
     {% if media_size == 'adapt' and product_card_product.featured_media %} style="padding-bottom: {{ 1 | divided_by: featured_media_aspect_ratio | times: 100 }}%;"{% endif %}
     >
  {%- liquid
      	assign second_img_position = product_card_product.featured_media.position
        assign second_img_position = second_img_position | plus: 1
      -%}
  <img
       srcset="{%- if product_card_product.featured_media.width >= 165 -%}{{ product_card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 240 -%}{{ product_card_product.featured_media | image_url: width: 240 }} 240w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 320 -%}{{ product_card_product.featured_media | image_url: width: 320 }} 320w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 480 -%}{{ product_card_product.featured_media | image_url: width: 480 }} 480w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 640 -%}{{ product_card_product.featured_media | image_url: width: 640 }} 640w,{%- endif -%}
               {%- if product_card_product.featured_media.width >= 840 -%}{{ product_card_product.featured_media | image_url: width: 840 }} 840w,{%- endif -%}"
       src="{{ product_card_product.featured_media | image_url: width: 320 }}"
       sizes="(min-width: {{ settings.container_lg_width }}px) 230px, (min-width: 990px) calc((100vw - 160px) / 4), (min-width: 750px) calc((100vw - 96px) / 3), calc((100vw - 48px) / 2)"
       alt="{{ product_card_product.featured_media.alt | escape }}"
       loading="lazy"
       decoding="async"
       class="motion-reduce"
       width="{{ product_card_product.featured_media.width }}"
       height="{{ product_card_product.featured_media.height }}"
       data-media-id="{{ section.id }}-{{ product_card_product.featured_media.id }}"
       >


  {%- if product_card_product.media[second_img_position] != nil and show_secondary_image -%}
  <img
       srcset="{%- if product_card_product.media[second_img_position].width >= 165 -%}{{ product_card_product.media[second_img_position] | image_url: width: 165 }} 165w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 240 -%}{{ product_card_product.media[second_img_position] | image_url: width: 240 }} 240w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 320 -%}{{ product_card_product.media[second_img_position] | image_url: width: 320 }} 320w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 480 -%}{{ product_card_product.media[second_img_position] | image_url: width: 480 }} 480w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 640 -%}{{ product_card_product.media[second_img_position] | image_url: width: 640 }} 640w,{%- endif -%}
               {%- if product_card_product.media[second_img_position].width >= 840 -%}{{ product_card_product.media[second_img_position] | image_url: width: 840 }} 840w{%- endif -%}"
       src="{{ product_card_product.media[second_img_position] | image_url: width: 320 }}"
       sizes="(min-width: {{ settings.container_lg_width }}px) 230px, (min-width: 990px) calc((100vw - 160px) / 4), (min-width: 750px) calc((100vw - 96px) / 3), calc((100vw - 48px) / 2)"
       alt="{{ product_card_product.media[second_img_position].alt | escape }}"
       loading="lazy"
       decoding="async"
       class="motion-reduce secondary__img"
       width="{{ product_card_product.media[second_img_position].width }}"
       height="{{ product_card_product.media[second_img_position].height }}"
       data-media-id="{{ section.id }}-{{ product_card_product.media[second_img_position].id }}"
       >
  {%- endif -%}
</div>