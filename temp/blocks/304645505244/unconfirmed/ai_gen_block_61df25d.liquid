{% doc %}
  @prompt
    Create a modern price display block for a Shopify product page. The block must include: sale price displayed large and prominent in red or accent color; original compare-at price with strikethrough in grey, smaller; a discount percentage badge (e.g. -30%) styled modern, rounded, red background with white text; horizontal layout: discount badge | sale price | original price strikethrough; modern typography: bold font for main price, normal for original; elegant spacing and alignment; responsive on mobile and desktop; premium, clean, modern style
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-price-display-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-price-display-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    flex-wrap: wrap;
  }

  .ai-price-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    line-height: 1;
    white-space: nowrap;
  }

  .ai-price-sale-{{ ai_gen_id }} {
    font-size: {{ block.settings.sale_price_size }}px;
    font-weight: 700;
    color: {{ block.settings.sale_price_color }};
    line-height: 1.2;
  }

  .ai-price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    font-weight: 400;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    line-height: 1.2;
    opacity: 0.7;
  }

  .ai-price-regular-{{ ai_gen_id }} {
    font-size: {{ block.settings.sale_price_size }}px;
    font-weight: 700;
    color: {{ block.settings.regular_price_color }};
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-price-display-container-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing_mobile }}px;
    }

    .ai-price-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.9 }}px;
      padding: {{ block.settings.badge_padding_vertical | times: 0.8 }}px {{ block.settings.badge_padding_horizontal | times: 0.8 }}px;
    }

    .ai-price-sale-{{ ai_gen_id }} {
      font-size: {{ block.settings.sale_price_size | times: 0.85 }}px;
    }

    .ai-price-compare-{{ ai_gen_id }} {
      font-size: {{ block.settings.compare_price_size | times: 0.85 }}px;
    }

    .ai-price-regular-{{ ai_gen_id }} {
      font-size: {{ block.settings.sale_price_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-price-display-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product %}
    {% assign current_variant = product.selected_or_first_available_variant %}
    {% assign compare_at_price = current_variant.compare_at_price %}
    {% assign price = current_variant.price %}
    {% assign on_sale = false %}
    {% assign discount_percentage = 0 %}

    {% if compare_at_price and compare_at_price > price %}
      {% assign on_sale = true %}
      {% assign discount_amount = compare_at_price | minus: price %}
      {% assign discount_percentage = discount_amount | times: 100.0 | divided_by: compare_at_price | round %}
    {% endif %}

    <div class="ai-price-display-container-{{ ai_gen_id }}">
      {% if on_sale and block.settings.show_badge %}
        <span class="ai-price-badge-{{ ai_gen_id }}">
          -{{ discount_percentage }}%
        </span>
      {% endif %}

      {% if on_sale %}
        <span class="ai-price-sale-{{ ai_gen_id }}">
          {{ price | money }}
        </span>
        {% if block.settings.show_compare_price %}
          <span class="ai-price-compare-{{ ai_gen_id }}">
            {{ compare_at_price | money }}
          </span>
        {% endif %}
      {% else %}
        <span class="ai-price-regular-{{ ai_gen_id }}">
          {{ price | money }}
        </span>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-price-display-container-{{ ai_gen_id }}">
      {% if block.settings.show_badge %}
        <span class="ai-price-badge-{{ ai_gen_id }}">
          -30%
        </span>
      {% endif %}
      <span class="ai-price-sale-{{ ai_gen_id }}">
        {{ 6999 | money }}
      </span>
      {% if block.settings.show_compare_price %}
        <span class="ai-price-compare-{{ ai_gen_id }}">
          {{ 9999 | money }}
        </span>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Modern price display",
  "settings": [
    {
      "type": "header",
      "content": "Display options"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show discount badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show original price",
      "default": true
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Discount badge"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Background",
      "default": "#c93131"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "badge_padding_vertical",
      "label": "Vertical padding",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "badge_padding_horizontal",
      "label": "Horizontal padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Sale price"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Color",
      "default": "#c93131"
    },
    {
      "type": "range",
      "id": "sale_price_size",
      "label": "Font size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Original price"
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "compare_price_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Regular price"
    },
    {
      "type": "color",
      "id": "regular_price_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Desktop spacing",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Mobile spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Modern price display"
    }
  ]
}
{% endschema %}
