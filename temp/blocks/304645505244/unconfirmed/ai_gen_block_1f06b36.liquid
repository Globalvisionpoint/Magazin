{% doc %}
  @prompt
    Create a modern price display block for a Shopify product page. The block must include: sale price displayed large and prominent in red or accent color; original compare-at price with strikethrough in grey, smaller; a discount percentage badge (e.g. -30%) styled modern, rounded, red background with white text; horizontal layout: discount badge | sale price | original price strikethrough; modern typography: bold font for main price, normal for original; elegant spacing and alignment; responsive on mobile and desktop; premium, clean, modern style
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-price-display-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-price-display-{{ ai_gen_id }}__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-price-display-{{ ai_gen_id }}__sale-price {
    font-size: {{ block.settings.sale_price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.sale_price_color }};
    line-height: 1.2;
    flex-shrink: 0;
  }

  .ai-price-display-{{ ai_gen_id }}__original-price {
    font-size: {{ block.settings.original_price_font_size }}px;
    font-weight: 400;
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .ai-price-display-{{ ai_gen_id }}__no-sale {
    font-size: {{ block.settings.sale_price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.regular_price_color }};
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-price-display-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-price-display-{{ ai_gen_id }}__badge {
      font-size: calc({{ block.settings.badge_font_size }}px * 0.9);
      padding: 4px 8px;
    }

    .ai-price-display-{{ ai_gen_id }}__sale-price {
      font-size: calc({{ block.settings.sale_price_font_size }}px * 0.85);
    }

    .ai-price-display-{{ ai_gen_id }}__original-price {
      font-size: calc({{ block.settings.original_price_font_size }}px * 0.85);
    }

    .ai-price-display-{{ ai_gen_id }}__no-sale {
      font-size: calc({{ block.settings.sale_price_font_size }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-price-display-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product.compare_at_price > product.price %}
    {% if block.settings.show_discount_badge %}
      {% assign discount_percentage = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
      <span class="ai-price-display-{{ ai_gen_id }}__badge">
        -{{ discount_percentage }}%
      </span>
    {% endif %}

    <span class="ai-price-display-{{ ai_gen_id }}__sale-price">
      {{ product.price | money }}
    </span>

    <span class="ai-price-display-{{ ai_gen_id }}__original-price">
      {{ product.compare_at_price | money }}
    </span>
  {% else %}
    <span class="ai-price-display-{{ ai_gen_id }}__no-sale">
      {{ product.price | money }}
    </span>
  {% endif %}
</div>

{% schema %}
{
  "name": "Price display",
  "settings": [
    {
      "type": "header",
      "content": "Discount badge"
    },
    {
      "type": "checkbox",
      "id": "show_discount_badge",
      "label": "Show discount badge",
      "default": true
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Background color",
      "default": "#c93131"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Sale price"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Color",
      "default": "#c93131"
    },
    {
      "type": "range",
      "id": "sale_price_font_size",
      "label": "Font size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Original price"
    },
    {
      "type": "color",
      "id": "original_price_color",
      "label": "Color",
      "default": "#999999"
    },
    {
      "type": "range",
      "id": "original_price_font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Regular price"
    },
    {
      "type": "color",
      "id": "regular_price_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Price display"
    }
  ]
}
{% endschema %}
